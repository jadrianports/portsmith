# env files — NEVER commit real secrets. .env.example IS committed (placeholders only).
.env
.env.local
.env*.local

# founder seed content (Plan 03-03) — the REAL content is James's, NOT committed.
# The committed `founder-content.example.ts` template IS the discoverable contract.
scripts/seed/founder-content.ts

# aurora demo seed content (Plan 22-02) — the tweakable demo copy, NOT committed.
# The committed `aurora-content.example.ts` template IS the discoverable contract.
scripts/seed/aurora-content.ts

# minimal/editorial demo seed content (Plan 23-01, D-15) — the tweakable demo copy, NOT committed.
# The committed `*-content.example.ts` templates ARE the discoverable contract.
scripts/seed/minimal-content.ts
scripts/seed/editorial-content.ts

# raw Lovable exports (Phase 11 / D-P11-07) — LOCAL only; heavy dep trees + third-party design.
# The committed artifacts are the template output folder, <slug>-source.png, and INGEST-MANIFEST.md.
lovable-exports/

# stray verification screenshots dumped in repo root (Playwright MCP saves here when
# given a bare filename) — keep them out of git; intentional assets live in /public or /src.
/*.png
/*.jpeg
/*.jpg

# vercel
.vercel

# typescript
*.tsbuildinfo

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor / OS
.DS_Store
.idea
*.swp

# local-only: private planning corpus, GSD tooling, scratch ideas, Playwright MCP cache
