# Portsmith — environment variables
# Copy to .env.local for development. Set the same keys in Vercel for deploy.
# Never commit .env.local. NEXT_PUBLIC_* values are exposed to the browser by
# design — never put a secret behind that prefix.

# --- Supabase ---------------------------------------------------------------
# Project URL and anon key are public (shipped to the browser). RLS is what
# protects data, not the secrecy of these values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key bypasses RLS. SERVER ONLY. Never prefix with NEXT_PUBLIC.
# Used by the contact API route, the page-view logger, and the admin setup script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site -------------------------------------------------------------------
# Canonical site origin, used for absolute URLs (sitemap, OG, JSON-LD, emails).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloudflare Turnstile ---------------------------------------------------
# Site key is public; secret key is server-only (used to verify tokens).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# --- Resend -----------------------------------------------------------------
# API key for transactional email (contact notifications).
RESEND_API_KEY=your-resend-api-key
# The verified "from" address. Must be on a domain with SPF/DKIM/DMARC set up.
RESEND_FROM_EMAIL=notifications@portsmith.app

# Supabase Auth email (signup confirmation, password reset) is routed through
# Resend via custom SMTP. Those SMTP credentials are configured in the Supabase
# dashboard (Auth > Email), not here. See docs/03-auth-flows.md.

# --- Admin bootstrap --------------------------------------------------------
# Email of the account to promote to admin. Read by scripts/promote-admin.ts,
# which is run once manually. This is NOT checked at runtime by the app.
ADMIN_EMAIL=you@example.com
